# SPA environment template.
# Copy this file to .env and set ERP_API_BASE_URL to the backend you want
# the dev server to proxy/build against.
#
# Common values:
#   Local backend:     http://localhost:3000/v1
#   Local Supabase CLI: http://localhost:54321/v1 (not typical; use the Node API)
#   UAT Render:        https://ata-lta-erp-api-uat.onrender.com/v1
#   Production:        https://ata-lta-erp-api.onrender.com/v1
#
ERP_API_BASE_URL=http://localhost:3000/v1
