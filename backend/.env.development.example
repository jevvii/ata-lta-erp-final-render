NODE_ENV=development
PORT=3000

# Supabase — REMOTE development target.
# For this dev environment you can reuse the same Supabase project used by UAT
# because the local API runs against Supabase directly; data is shared unless
# you point to a separate project. Edit these values from your Supabase
# dashboard (Settings → API) or from your Render "erp-uat-secrets" group.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service-role key; never expose to browser
SUPABASE_STORAGE_BUCKET=ata-lta-erp-documents-dev

# PostgreSQL — direct connection for node-pg-migrate when running locally.
# For a remote Supabase project, use the connection string from Database →
# Connection string (PSQL). Session/Transaction pooler strings both work.
# Example:
# postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ata_lta_erp

# Frontend — the local SPA dev server origin.
FRONTEND_URL=http://localhost:8080

# Logging
LOG_LEVEL=debug
