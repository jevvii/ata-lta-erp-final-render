    },
    {
      "ID": "document-lifecycle-glacier-to-deep-archive",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "entities/"
      },
      "Transitions": [
        {
          "Days": 1095,
          "StorageClass": "DEEP_ARCHIVE"
        }
      ]
    }
  ]
