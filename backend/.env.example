NODE_ENV=development
PORT=3000

# Supabase (backend/Auth)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service-role key; never expose to browser
SUPABASE_JWT_SECRET=           # optional; used for verifying tokens locally if needed

# AWS
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_ENDPOINT_URL=                  # optional: for localstack/dev (e.g. http://localhost:4566)

# S3 buckets
S3_DOCUMENT_BUCKET=ata-lta-erp-documents-dev
S3_SPA_BUCKET=ata-lta-erp-spa-dev

# CloudFront (document downloads)
CLOUDFRONT_KEY_ID=K...
CLOUDFRONT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
CLOUDFRONT_DOCUMENT_DOMAIN=https://docs.ata-lta.ph

# PostgreSQL (direct connection for migrations / local fallback)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ata_lta_erp

# Frontend
FRONTEND_URL=http://localhost:8080

# Logging
LOG_LEVEL=info
