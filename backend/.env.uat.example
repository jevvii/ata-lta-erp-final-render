NODE_ENV=production
PORT=3000

# Supabase — UAT deployment target.
# Values are injected by Render from the erp-uat-secrets environment group.
SUPABASE_URL=${SUPABASE_URL}
SUPABASE_SERVICE_KEY=${SUPABASE_SERVICE_KEY}
SUPABASE_STORAGE_BUCKET=${SUPABASE_STORAGE_BUCKET:-ata-lta-erp-documents-uat}

# PostgreSQL — UAT direct connection (optional; most modules use Supabase REST).
DATABASE_URL=${DATABASE_URL}

# Frontend — Render Static Site origin.
FRONTEND_URL=${FRONTEND_URL}

# Logging
LOG_LEVEL=info
