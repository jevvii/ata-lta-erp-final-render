{
  "name": "ata-lta-erp-backend",
  "version": "0.1.0",
  "description": "Backend API for the ATA & LTA Accounting Firm ERP",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "dev:local": "node scripts/run.js local",
    "dev:uat": "node scripts/run.js uat",
    "dev:prod": "node scripts/run.js prod",
    "start": "node src/app.js",
    "start:local": "node scripts/run.js local",
    "start:uat": "node scripts/run.js uat",
    "start:prod": "node scripts/run.js prod",
    "test": "PORT=0 jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "migrate": "node-pg-migrate",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "migrate:remote": "node scripts/migrate-remote.js",
    "migrate:remote:uat": "node scripts/migrate-remote.js uat",
    "create-bucket": "node scripts/create-storage-bucket.js",
    "create-bucket:uat": "node scripts/create-storage-bucket.js uat",
    "reset:remote": "node scripts/reset-remote.js",
    "reset:remote:uat": "node scripts/reset-remote.js uat",
    "verify:auth": "node scripts/verify-supabase-auth.js",
    "setup:env": "cp .env.example .env"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.13.0",
    "puppeteer": "^19.11.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.8.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "tests"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
